# Gmail account used by nodemailer to send form submissions
GMAIL_USER=your-gmail@gmail.com

# Google Account → Security → App passwords (requires 2FA)
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional overrides (use for local testing)
# CONTACT_RECIPIENTS=firedateto@gmail.com
# ANALYSIS_REQUEST_EMAIL=firedateto@gmail.com